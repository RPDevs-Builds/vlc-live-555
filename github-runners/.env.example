# GitHub Actions Runner Configuration
GITHUB_TOKEN=your_personal_access_token_with_repo_scope

# --- Performance & Build Tuning ---
# Cap parallel compilation jobs (e.g., 4) to prevent OOM errors on smaller runners
MAKE_JOBS=4
# Path inside the container for persistent compiler cache (map to host volume)
CCACHE_DIR=/home/runner/.cache/ccache

# --- Feature & Audit Configuration ---
# Additional flags to pass to ./configure during VLC build
# Useful for enabling/disabling specific modules during the upcoming audit
VLC_CONFIGURE_FLAGS=--enable-debug
