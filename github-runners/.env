# GitHub Actions Runner Configuration
GITHUB_TOKEN=your_personal_access_token_with_repo_scope

# --- Performance & Build Tuning ---
MAKE_JOBS=4
CCACHE_DIR=/home/runner/.cache/ccache

# --- Feature & Audit Configuration ---
# Enabled recommended hardware acceleration modules
VLC_CONFIGURE_FLAGS=--enable-libva --enable-vdpau --enable-nvdec --enable-omxil
